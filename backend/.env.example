# ===========================================================================
# Backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ===========================================================================

# ---------- App ----------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
# Comma-separated list of allowed origins for CORS (admin panel, local dev, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Public base URL of this API (used to build absolute image URLs)
APP_URL=http://localhost:5000
# Public URL of the admin panel / web client (used in emails & OAuth redirects)
CLIENT_URL=http://localhost:5173

# ---------- Database ----------
# IMPORTANT: include a database name in the path (here: `sunny_club`) so this
# project gets its OWN database and does not write into the cluster's default
# `test` database (which may already contain other collections).
# Local:  mongodb://127.0.0.1:27017/sunny_club
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sunny_club?appName=Cluster0
MONGO_URI=mongodb://127.0.0.1:27017/sunny_club

# ---------- JWT ----------
# Generate strong random secrets, e.g. `openssl rand -hex 32`. Min 16 chars.
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Email verification ----------
# When true, unverified local accounts can sign in but cannot create clubs /
# events, favorite, or edit their profile until they confirm their email OTP.
REQUIRE_EMAIL_VERIFICATION=true

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---------- Keep-alive (prevent free-host sleep) ----------
# Self-pings APP_URL/<prefix>/health on an interval (production only) so free
# hosts like Render don't spin the service down. Requires APP_URL set to the
# public URL (e.g. https://<service>.onrender.com).
KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL_MS=600000

# ---------- File uploads ----------
# Max upload size in bytes (5 MB)
MAX_FILE_SIZE=5242880
# Optional override. Leave empty to auto-use monorepo `uploads/` locally or
# `backend/uploads/` when deployed standalone (e.g. Render rootDir: backend).
UPLOADS_DIR=

# ---------- SMTP / Email ----------
# For Gmail: host smtp.gmail.com, port 587, SECURE=false, and SMTP_PASS must be
# a Gmail App Password (not the account password). Leave SMTP_HOST empty to skip
# real sending in dev (emails are logged instead).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM_NAME=Sports Club Platform
EMAIL_FROM_ADDRESS=your-email@gmail.com

# ---------- Google OAuth ----------
# Comma-separated accepted audiences: your Android, iOS and Web OAuth client IDs.
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# ---------- Apple Sign In ----------
# Your app's Apple client id / bundle id (identity-token audience).
APPLE_CLIENT_ID=

# ---------- Cloudinary (persistent image storage) ----------
# Set all three (from your Cloudinary dashboard) so uploads persist on hosts
# with an ephemeral disk (e.g. Render). Leave blank to use local disk in dev.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Logging ----------
# error | warn | info | http | debug
LOG_LEVEL=debug

# ---------- Production (Render) ----------
# When deploying to Render, set at minimum:
#   NODE_ENV=production
#   MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/sunny_club
#   APP_URL=https://<your-service>.onrender.com
#   CLIENT_URL=https://<your-admin-panel-url>
#   CORS_ORIGINS=https://<your-admin-panel-url>
#   JWT_ACCESS_SECRET / JWT_REFRESH_SECRET — strong random strings (min 16 chars)
# Render injects PORT automatically — do not hard-code it in production.
# See backend/README.md and docs/DEPLOYMENT.md for full steps.
