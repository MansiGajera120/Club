{
  "name": "club-backend",
  "version": "1.0.0",
  "description": "Sports Club Discovery Platform — REST API (Node.js + Express + MongoDB)",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed": "node scripts/seed.js",
    "seed:clubs": "node scripts/seed-clubs.js",
    "test": "node --test"
