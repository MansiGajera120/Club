# ============================================================
# Root workspace .gitignore
# App-specific ignores live inside each app's own .gitignore
# ============================================================

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Editors / IDEs ----------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.iml
*.swp

# ---------- Environment ----------
.env
.env.*
!.env.example

# ---------- Node ----------
node_modules/
dist/
build/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Logs ----------
logs/
*.log

# ---------- Runtime uploads ----------
# Keep the folder structure, ignore uploaded binaries
uploads/**/*
!uploads/**/.gitkeep

# ---------- Flutter ----------
mobile_app/.dart_tool/
mobile_app/.flutter-plugins
mobile_app/.flutter-plugins-dependencies
mobile_app/build/
mobile_app/.pub-cache/
mobile_app/.pub/
mobile_app/**/*.g.dart
mobile_app/**/*.freezed.dart
mobile_app/ios/Pods/
mobile_app/android/.gradle/
mobile_app/android/local.properties

# ---------- Temp ----------
*.tmp
*.temp
tmp/
